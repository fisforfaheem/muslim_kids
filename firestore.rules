rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read all users (needed for teacher to see students)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Allow users to read and write to their own subcollections
      match /prayers/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Prayer times collection - allow users to access their own prayer times
    match /user_prayer_times/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Public prayer times collection - allow all users to read
    match /public_prayer_times/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Class-related collections - allow authenticated users to access
    match /classes/{classId} {
      allow read, write: if request.auth != null;
    }
    
    match /class_enrollments/{enrollmentId} {
      allow read, write: if request.auth != null;
    }
    
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Allow read access to public collections
    match /islamic_videos/{video} {
      allow read: if true;
    }
    
    match /islamic_events/{event} {
      allow read: if true;
    }
    
    // Default rule for other collections
    match /{collection}/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
